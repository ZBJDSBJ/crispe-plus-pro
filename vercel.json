{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/optimize.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/optimize",
      "dest": "/api/optimize.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
